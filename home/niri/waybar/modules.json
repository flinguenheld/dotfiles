{
  "backlight": {
    "interval": 2,
    "align": 0,
    "rotate": 0,
    //"device": "amdgpu_bl0",
    "format": "{icon} {percent}%",
    "format-icons": [
      "´ùØ",
      "´ù£",
      "´ùŞ",
      "´ùş"
    ],
    "on-click": "",
    "on-click-middle": "",
    "on-click-right": "",
    "on-update": "",
    "on-scroll-up": "light -A 5%",
    "on-scroll-down": "light -U 5%",
    "smooth-scrolling-threshold": 1,
  },
  "battery": {
    "interval": 60,
    "align": 0,
    "rotate": 0,
    //"bat": "BAT1",
    //"adapter": "ACAD",
    "full-at": 100,
    "design-capacity": false,
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "´âğ {capacity}%",
    "format-plugged": "´çĞ {capacity}%",
    "format-full": "{icon} Full",
    //"format-good": "",
    "format-alt": "{icon} {time}",
    "format-icons": [
      "´ëä",
      "´ëâ",
      "´ëé",
      "´ëü",
      "´ëÇ"
    ],
    "format-time": "{H}h {M}min",
    "tooltip": true,
  },
  "bluetooth": {
    //"controller": "controller1",
    //"format-device-preference": "",
    "format": " ´èö {status} ",
    "format-on": " ¾░é░ {status} ",
    "format-off": " ¾░é▓ {status} ",
    "format-disabled": " ¾░é▓ {status} ",
    "format-connected": " ¾░é░ {device_alias} ",
    "format-connected-battery": "¾░Ñé {device_alias}, {device_battery_percentage}%",
    "tooltip": true,
    "tooltip-format": "{controller_alias}\t{controller_address}",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "on-click": "overskride"
    // "on-click-right": "blueman-manager"
  },
  "clock#date": {
    "interval": 60,
    "align": 0,
    "rotate": 0,
    "timezone": "France/Paris",
    "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>",
    "format": "¾░Ñö  {:%a %b %d, %G}",
    "calendar": {
      "mode": "year",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "on-click-right": "mode",
      "format": {
        "months": "<span color='#ffead3'><b>{}</b></span>",
        "days": "<span color='#ecc6d9'><b>{}</b></span>",
        "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
        "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
        "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
      }
    },
    "actions": {
      "on-click-right": "mode",
      "on-click-forward": "tz_up",
      "on-click-backward": "tz_down",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    }
  },
  "clock#time": {
    "interval": 1,
    "align": 0,
    "rotate": 0,
    "timezone": "France/Paris",
    "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>",
    // "format": "¾░Ñö  {:%I:%M %p}",
    "format": " {:%I:%M} ",
    "format-alt": " {:%I:%M:%S} ",
    // "format-alt": "¾▒ææ  {:%I:%M:%S %p}",
    // "format-alt": "´ü│ {:%a %b %d, %G}"
  },
  "custom/themes": {
    "format": " ¯┐î  ",
    "tooltip": false,
    "on-click": "$HOME/.config/niri/scripts/theme_menu"
  },
  "custom/power": {
    "format": "ÔÅ╗",
    "tooltip": false,
    "on-click": "$HOME/.config/niri/scripts/power_menu"
  },
  "cpu": {
    "interval": 5,
    "format": "´Æ╝  {usage}%"
  },
  "memory": {
    "interval": 5,
    "format": "¯┐à  {percentage}%"
  },
  "disk": {
    "interval": 30,
    "format": "´âç  {free}"
  },
  "network": {
    "interval": 5,
    "format-wifi": "´ç½  {essid}",
    "format-alt": "¾░ûş  {ipaddr}/{cidr}",
    "format-ethernet": "´âİ  {bandwidthUpBits} | ´âù {bandwidthDownBits}",
    "format-linked": "¯╝ë {ifname} (No IP)",
    "format-disconnected": "¾░îÖ Disconnected",
    "format-disabled": "´ô┤ Disabled",
    // "format-alt": "´âİ {bandwidthUpBits} | ´âù {bandwidthDownBits}",
    "tooltip-format": "¯¢ä  {ifname} via {gwaddr}",
    "on-click-right": "alacritty -e nmtui"
  },
  "custom/expressvpn": {
    "interval": 5,
    "exec": "~/.config/niri/scripts/expressvpn",
    "on-click": "expressvpn connect",
    "on-click-right": "expressvpn disconnect"
  },
  "pulseaudio#speaker": {
    "format": "{icon} {volume}%",
    "format-muted": "¯╗¿  Mute",
    "format-bluetooth": "´èô {volume}% {format_source}",
    "format-bluetooth-muted": "´èô Mute",
    "format-source": "¯┤â {volume}%",
    "format-source-muted": "´ä▒",
    "format-icons": {
      // "headphone": "´ÇÑ",
      // "hands-free": "´şÅ",
      // "headset": "´şı",
      // "phone": "´éò",
      // "portable": "´éò",
      // "car": "´å╣",
      "default": [
        "´ÇĞ",
        "´Çğ",
        "´Ç¿ "
      ]
    },
    "on-click": "wpctl set-mute @DEFAULT_SINK@ toggle",
    "on-click-right": "pavucontrol -t 3",
    "on-scroll-down": "wpctl set-volume @DEFAULT_SINK@ 5%-",
    "on-scroll-up": "wpctl set-volume @DEFAULT_SINK@ 5%+"
  },
  "pulseaudio#mic": {
    "format": "{format_source}",
    "format-source": "¯┤â {volume}%",
    "format-source-muted": "¯┐å  Mute",
    "on-click": "wpctl set-mute @DEFAULT_SOURCE@ toggle",
    "on-click-right": "pavucontrol -t 4",
    "on-scroll-down": "wpctl set-volume @DEFAULT_SOURCE@ 5%-",
    "on-scroll-up": "wpctl set-volume @DEFAULT_SOURCE@ 5%+"
  },
  "idle_inhibitor": {
    "format": " {icon}  ",
    "format-icons": {
      "activated": "´ü«",
      "deactivated": "´ü░"
    },
    "timeout": 30
  },
  "niri/workspaces": {
    // "current-only": true,
    "format": "{value}"
  },
  "tray": {
    "icon-size": 16,
    "spacing": 10
  }
}
